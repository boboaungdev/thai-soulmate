// This is your Prisma schema file

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  name     String
  avatar   String?
  email    String  @unique
  password String
  role     Role    @default(USER)

  registerInterest RegisterInterest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegisterInterest {
  id String @id @default(cuid())

  prefix          String
  name            String
  dob             DateTime
  gender          String
  nationality     String
  currentLocation String

  email        String  @unique
  phoneCountry String
  phone        String
  source       String
  otherSource  String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationForm {
  id String @id @default(cuid())

  // Step 1: Personal Details
  personalDetails Json

  // Contact information
  contact Json

  // Step 2: Occupation / Education
  career Json

  // Step 3: Height / Weight / Religion
  appearance Json

  // Step 4-5: Personality / About
  personality Json

  // Step 6-7: Lifestyle / Interests
  lifestyle Json

  // Relationship goals
  relationshipGoals Json

  // Preferred partner
  idealPartner Json

  // Financial information
  financial Json

  // Photos
  photos Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  STAFF
  USER
}
